<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_company_asset_tree" model="ir.ui.view">
        <field name="name">company.asset.tree</field>
        <field name="model">company.asset</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="serial_number"/>
            </tree>
        </field>
    </record>

    <record id="view_company_asset_form" model="ir.ui.view">
        <field name="name">company.asset.form</field>
        <field name="model">company.asset</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="serial_number"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="company_asset_action" model="ir.actions.act_window">
        <field name="name">Company Assets</field>
        <field name="res_model">company.asset</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="company_asset_root_menu"
              name="Company Assets"
              sequence="10"/>

    <menuitem id="company_asset_menu"
              name="Assets"
              parent="company_asset_root_menu"
              action="company_asset_action"/>
              
</odoo>
